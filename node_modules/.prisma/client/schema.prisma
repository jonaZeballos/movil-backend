// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id       String    @id @map("id_rol") @db.VarChar(1000)
  rol      String    @db.VarChar(200)
  usuarios Usuario[]

  @@map("roles")
}

model Usuario {
  id            String   @id @map("id_usuario") @db.VarChar(1000)
  nombres       String   @db.VarChar(100)
  apellidos     String   @db.VarChar(100)
  username      String   @db.VarChar(30)
  email         String   @db.VarChar(200)
  password      String   @db.VarChar(1024)
  fechaCreacion DateTime @map("fecha_creacion") @db.Date

  idRol String? @map("id_rol") @db.VarChar(1000)
  rol   Rol?    @relation(fields: [idRol], references: [id])

  cliente   Cliente?
  telefonos Telefono[]
  ordenes   OrdenServicio[]

  @@map("usuario")
}

model Cliente {
  idUsuario       String @id @map("id_usuario") @db.VarChar(1000)
  razonSocial     String @map("razon_social") @db.VarChar(100)
  numeroDocumento BigInt @unique @map("numero_documento") @db.BigInt

  usuario Usuario  @relation(fields: [idUsuario], references: [id], onDelete: Cascade)
  equipos Equipo[]

  @@map("cliente")
}

model Telefono {
  id     String @id @map("id_telefono") @db.VarChar(1000)
  numero BigInt @db.BigInt

  idUsuario String  @map("id_usuario") @db.VarChar(1000)
  usuario   Usuario @relation(fields: [idUsuario], references: [id])

  @@map("telefono")
}

model TipoEquipo {
  id      String   @id @map("id_tipo_equipo") @db.VarChar(1000)
  nombre  String   @map("nombre_tipo") @db.VarChar(200)
  equipos Equipo[]

  @@map("tipo_equipo")
}

model Marca {
  id      String   @id @map("id_marca") @db.VarChar(1000)
  nombre  String   @map("nombre_marca") @db.VarChar(1024)
  modelos Modelo[]

  @@map("marca")
}

model Modelo {
  id              String   @id @map("id_modelo") @db.VarChar(1000)
  nombreModelo    String   @map("nombre_modelo") @db.VarChar(100)
  nombreComercial String   @map("nombre_comercial") @db.VarChar(100)
  lanzamiento     DateTime @db.Date

  idMarca String @map("id_marca") @db.VarChar(1000)
  marca   Marca  @relation(fields: [idMarca], references: [id])

  equipos Equipo[]

  @@map("modelo")
}

model Equipo {
  id            String   @id @map("id_equipo") @db.VarChar(1000)
  nroSerie      String   @map("nro_serie") @db.VarChar(200)
  fechaRegistro DateTime @map("fecha_registro") @db.Date

  idCliente    String @map("id_cliente") @db.VarChar(1000)
  idTipoEquipo String @map("id_tipo_equipo") @db.VarChar(1000)
  idModelo     String @map("id_modelo") @db.VarChar(1000)

  cliente    Cliente         @relation(fields: [idCliente], references: [idUsuario])
  tipoEquipo TipoEquipo      @relation(fields: [idTipoEquipo], references: [id])
  modelo     Modelo          @relation(fields: [idModelo], references: [id])
  ordenes    OrdenServicio[]

  @@map("equipo")
}

model EstadoOrdenServicio {
  id      String          @id @map("id_estado_orden_pago") @db.VarChar(1000)
  nombre  String          @map("nombre_estado_ops") @db.VarChar(20)
  ordenes OrdenServicio[]

  @@map("estado_orden_servicio")
}

model Prioridad {
  id        String          @id @map("id_prioridad") @db.VarChar(1000)
  prioridad String          @db.VarChar(100)
  ordenes   OrdenServicio[]

  @@map("prioridad")
}

model OrdenServicio {
  id             String    @id @map("id_orden_servicio") @db.VarChar(1000)
  codigo         Int
  fechaRecepcion DateTime  @map("fecha_recepcion") @db.Date
  fechaEntrega   DateTime? @map("fecha_entrega") @db.Date
  diagnostico    String    @db.VarChar(400)
  garantiaDias   Int       @map("garantia_dias")
  observaciones  String?   @db.VarChar(1024)

  idEquipo    String  @map("id_equipo") @db.VarChar(1000)
  idTecnico   String? @map("id_usuario") @db.VarChar(1000)
  idEstado    String  @map("id_estado_orden_pago") @db.VarChar(1000)
  idPrioridad String  @map("id_prioridad") @db.VarChar(1000)

  equipo    Equipo              @relation(fields: [idEquipo], references: [id])
  tecnico   Usuario?            @relation(fields: [idTecnico], references: [id])
  estado    EstadoOrdenServicio @relation(fields: [idEstado], references: [id])
  prioridad Prioridad           @relation(fields: [idPrioridad], references: [id])

  @@map("orden_servicio")
}
